<header class="site-header">
  <div class="site-header__inner container">
    <a href="/" class="site-header__logo">
      <img src="/assets/img/bangbanglogo-173w.png" alt="Bang Bang Auto Detailing" width="173" height="113">
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      <ul class="site-nav__list">
        <li class="site-nav__item">
          <a href="/" class="site-nav__link{% if page.url == '/' %} site-nav__link--active{% endif %}">Home</a>
        </li>
        <li class="site-nav__item">
          <a href="/about-us/" class="site-nav__link{% if page.url == '/about-us/' %} site-nav__link--active{% endif %}">About Us</a>
        </li>
        <li class="site-nav__item" style="position: relative;">
          <a href="/services/" class="site-nav__link{% if page.url == '/services/' %} site-nav__link--active{% endif %}">Services</a>
          <ul class="site-nav__dropdown">
            <li><a href="/full-exterior-and-interior-detail/" class="site-nav__dropdown-link">Full Exterior and Interior Detail</a></li>
            <li><a href="/ceramic-coating/" class="site-nav__dropdown-link">Ceramic Coating</a></li>
            <li><a href="/paint-and-trim-restoration/" class="site-nav__dropdown-link">Paint Correction</a></li>
            <li><a href="/vinyl-removal/" class="site-nav__dropdown-link">Vinyl Removal</a></li>
            <li><a href="/boats-detailing/" class="site-nav__dropdown-link">Boats Detailing</a></li>
            <li><a href="/rvs-detailing/" class="site-nav__dropdown-link">RVs Detailing</a></li>
          </ul>
        </li>
        <li class="site-nav__item">
          <a href="/see-our-work/" class="site-nav__link{% if page.url == '/see-our-work/' %} site-nav__link--active{% endif %}">See Our Work</a>
        </li>
        <li class="site-nav__item">
          <a href="/contact-us/" class="site-nav__link{% if page.url == '/contact-us/' %} site-nav__link--active{% endif %}">Contact Us</a>
        </li>
      </ul>
    </nav>

    <a href="https://book.housecallpro.com/book/Bang-Bang-Auto-Detailing/e1bfaf3c4d614223966fdf2a433df417?v2=true" class="btn btn--primary site-header__cta" target="_blank" rel="noopener">Book Online</a>

    <a href="tel:{{ phone }}" class="site-header__phone" aria-label="Call {{ phone }}">
      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
        <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
      </svg>
    </a>

    <button class="hamburger" id="hamburger-toggle" aria-label="Open menu" aria-expanded="false">
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>
</header>

<div class="drawer__overlay" id="drawer-overlay"></div>
<aside class="drawer" id="mobile-drawer" aria-label="Mobile navigation">
  <button class="modal__close" id="drawer-close" aria-label="Close menu">&times;</button>
  <nav>
    <a href="/" class="drawer__nav-link">Home</a>
    <a href="/about-us/" class="drawer__nav-link">About Us</a>
    <a href="/services/" class="drawer__nav-link">Services</a>
    <a href="/full-exterior-and-interior-detail/" class="drawer__nav-link">Full Exterior and Interior Detail</a>
    <a href="/ceramic-coating/" class="drawer__nav-link">Ceramic Coating</a>
    <a href="/paint-and-trim-restoration/" class="drawer__nav-link">Paint Correction</a>
    <a href="/vinyl-removal/" class="drawer__nav-link">Vinyl Removal</a>
    <a href="/boats-detailing/" class="drawer__nav-link">Boats Detailing</a>
    <a href="/rvs-detailing/" class="drawer__nav-link">RVs Detailing</a>
    <a href="/see-our-work/" class="drawer__nav-link">See Our Work</a>
    <a href="/contact-us/" class="drawer__nav-link">Contact Us</a>
  </nav>
  <div style="margin-top: auto; padding-top: var(--space-xl);">
    <p><a href="tel:{{ phone }}">{{ phone }}</a></p>
    <p><a href="mailto:{{ email }}">{{ email }}</a></p>
  </div>
</aside>
