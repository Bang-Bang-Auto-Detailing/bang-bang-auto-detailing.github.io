---
title: Contact Us
description: Contact Bang Bang Auto Detailing in Orlando, FL. Call, email, or book online for premium mobile auto detailing services.
layout: default
permalink: /contact-us/
uses_map: true
---

<section class="hero section--dark" style="min-height: auto; padding-bottom: var(--space-xl);">
  <div class="container text-center">
    <p class="text-green" style="font-weight: 700;">Bang Bang Auto Detailing</p>
    <h1>Contact Us</h1>
    <p class="text-white" style="max-width: 600px; margin-inline: auto;">We make car care easy. With a simple phone call, our expert team comes to you, fully equipped to provide <a href="/services/" class="text-pink">top-notch detailing services</a>.</p>
  </div>
</section>

<section class="section" style="padding-block: var(--space-md);">
  <div class="container">
    <div class="grid grid--2" style="gap: var(--space-md);">
      <div>
        <h3 class="text-green">Contact Info</h3>
        <p><a href="tel:{{ phone }}">{{ phone }}</a></p>
        <p><a href="mailto:{{ email }}">{{ email }}</a></p>

        <h3 class="text-green" style="margin-top: var(--space-xl);">Business Hours</h3>
        <dl>
          <div style="display: flex; justify-content: space-between; margin-bottom: var(--space-sm); max-width: 300px;">
            <dt>Mon - Sat</dt>
            <dd>9:00 am - 6:00 pm</dd>
          </div>
          <div style="display: flex; justify-content: space-between; max-width: 300px;">
            <dt>Sunday</dt>
            <dd>Closed</dd>
          </div>
        </dl>

        <div class="social-icons" style="margin-top: var(--space-xl);">
          <a href="https://facebook.com/BangBangdetail" target="_blank" rel="noopener" aria-label="Facebook" class="social-icons__link" style="color: var(--color-dark);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="https://instagram.com/bangbangdetail/" target="_blank" rel="noopener" aria-label="Instagram" class="social-icons__link" style="color: var(--color-dark);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/></svg>
          </a>
          <a href="https://youtube.com/@bangbangdetail6958" target="_blank" rel="noopener" aria-label="YouTube" class="social-icons__link" style="color: var(--color-dark);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0C.488 3.45.029 5.804 0 12c.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0C23.512 20.55 23.971 18.196 24 12c-.029-6.185-.484-8.549-4.385-8.816zM9 16V8l8 4-8 4z"/></svg>
          </a>
          <a href="https://www.google.com/maps/place/Bang+Bang+Auto+Detailing/" target="_blank" rel="noopener" aria-label="Google My Business" class="social-icons__link" style="color: var(--color-dark);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <form action="https://api.web3forms.com/submit" method="post" class="contact-form">
          <input type="hidden" name="access_key" value="{{ form_key }}">
          <div class="grid grid--2">
            <div class="contact-form__field">
              <label class="contact-form__label" for="contact-name">Name:</label>
              <input class="contact-form__input" type="text" name="Name" id="contact-name" required style="color: var(--color-dark); border-color: var(--color-dark);">
            </div>
            <div class="contact-form__field">
              <label class="contact-form__label" for="contact-phone">Phone:</label>
              <input class="contact-form__input" type="tel" name="Phone" id="contact-phone" style="color: var(--color-dark); border-color: var(--color-dark);">
            </div>
          </div>
          <div class="contact-form__field">
            <label class="contact-form__label" for="contact-email">Email:</label>
            <input class="contact-form__input" type="email" name="Email" id="contact-email" style="color: var(--color-dark); border-color: var(--color-dark);">
          </div>
          <div class="contact-form__field">
            <label class="contact-form__label" for="contact-message">Message:</label>
            <textarea class="contact-form__textarea" name="Message" id="contact-message" rows="3" style="color: var(--color-dark); border-color: var(--color-dark);"></textarea>
          </div>
          <button type="submit" class="btn btn--primary">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<section style="background: var(--color-light); padding: var(--space-md) 0;">
  <div class="container">
    <div id="map" class="map" style="height: 250px;"></div>
  </div>
</section>
