<!doctype html>
<html lang="en">

{% assign title = title | concat: ' | Bang Bang Auto Detailing' %}

<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <link rel="canonical" href="https://www.bangbangautodetailing.com{{ page.url }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="apple-touch-icon" href="/assets/img/Untitled+1630+x+900+px.jpg">
  <link rel="icon" type="image/x-icon" href="/assets/img/site_favicon_16_1738719270240.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Quicksand:wght@400;500;700&family=Raleway:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/new-style.css">
  <meta name="google-site-verification" content="62UuktzIjpheTufmrBeShFh4p_U65mgdQq4ssYtAo24">
  <meta name="description" content="{{ description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://www.bangbangautodetailing.com{{ page.url }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="/assets/img/209-1920w.webp">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="/assets/img/209-1920w.webp">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Bang Bang Auto Detailing",
      "url": "https://www.bangbangautodetailing.com/"
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Bang Bang Auto Detailing",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "2 N Orange Ave",
        "addressLocality": "Orlando",
        "addressRegion": "FL",
        "postalCode": "32801",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "28.54211",
        "longitude": "-81.379036"
      },
      "url": "https://www.bangbangautodetailing.com",
      "telephone": "{{ phone }}",
      "email": "{{ email }}",
      "logo": "https://www.bangbangautodetailing.com/assets/img/bangbanglogo.png",
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "09:00", "closes": "18:00" }
      ],
      "priceRange": "$$",
      "sameAs": [
        "https://facebook.com/BangBangdetail",
        "https://instagram.com/bangbangdetail",
        "https://youtube.com/@bangbangdetail6958"
      ]
    }
  </script>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-7CN3YZ1T57"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-7CN3YZ1T57');
  </script>
</head>

<body{% if page_alias %} data-page-alias="{{ page_alias }}"{% endif %}>
  {% include "new-header.liquid" %}

  <main>
    {{ content }}
  </main>

  {% include "new-footer.liquid" %}

  {% if uses_gallery %}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/photoswipe/5.4.4/photoswipe.min.css" integrity="sha512-LFWtdAXHQuwUGH9cImO9blA3a3GfQNkpF2uRlhaOpSbDevNyK1rmAjs13mtpjvWyi+flP7zYWboqY+8Mkd42xA==" crossorigin="anonymous" referrerpolicy="no-referrer">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/photoswipe/5.4.4/umd/photoswipe.umd.min.js" integrity="sha512-BXwwGU7zCXVgpT2jpXnTbioT9q1Byf7NEXVxovTZPlNvelL2I/4LjOaoiB2a19L+g5za8RbkoJFH4fMPQcjFFw==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/photoswipe/5.4.4/umd/photoswipe-lightbox.umd.min.js" integrity="sha512-D16CBrIrVF48W0Ou0ca3D65JFo/HaEAjTugBXeWS/JH+1KNu54ZOtHPccxJ7PQ44rTItUT6DSI6xNL+U34SuuQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  {% endif %}
  {% if uses_map %}
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.13.0/mapbox-gl.css" rel="stylesheet">
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.13.0/mapbox-gl.js"></script>
  <script>window.MAPBOX_KEY = "{{ mapbox_key }}";</script>
  {% endif %}
  <script>
    // Hamburger menu
    const toggle = document.getElementById('hamburger-toggle');
    const drawer = document.getElementById('mobile-drawer');
    const overlay = document.getElementById('drawer-overlay');
    const close = document.getElementById('drawer-close');

    function openDrawer() {
      drawer.setAttribute('open', '');
      overlay.classList.add('is-visible');
      toggle.setAttribute('aria-expanded', 'true');
    }
    function closeDrawer() {
      drawer.removeAttribute('open');
      overlay.classList.remove('is-visible');
      toggle.setAttribute('aria-expanded', 'false');
    }

    toggle?.addEventListener('click', () => drawer.hasAttribute('open') ? closeDrawer() : openDrawer());
    close?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);

    // PhotoSwipe
    if (typeof PhotoSwipeLightbox !== 'undefined' && document.getElementById('gallery')) {
      const lightbox = new PhotoSwipeLightbox({
        gallery: '#gallery',
        children: 'a',
        pswpModule: PhotoSwipe
      });
      lightbox.init();
    }

    // Mapbox
    if (typeof mapboxgl !== 'undefined' && document.getElementById('map')) {
      const map = new mapboxgl.Map({
        accessToken: window.MAPBOX_KEY,
        container: 'map',
        style: 'mapbox://styles/mapbox/streets-v12',
        center: [-81.379039, 28.54211],
        zoom: 13
      });
      map.addControl(new mapboxgl.FullscreenControl());
      map.addControl(new mapboxgl.NavigationControl());
      new mapboxgl.Marker().setLngLat([-81.379039, 28.54211]).addTo(map);
    }
  </script>
</body>
</html>
